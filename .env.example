# Baidu Qianfan API key for AI image analysis
# Get one at: https://console.bce.baidu.com/qianfan/ais/console/apiKey
API_KEY=your_api_key_here

# Optional: Baidu Qianfan app id, only if your key requires it
# APP_ID=your_app_id_here

# Self-hosted PostgreSQL connection string
# Run `npm run db:start` to start the Docker Postgres container
DATABASE_URL=postgresql://clearpantry:clearpantry@localhost:5432/clearpantry?schema=public

# Tencent Cloud COS configuration for image storage
# Leave these empty to store images locally in data/images/
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=your_bucket_name
COS_REGION=ap-guangzhou
# Optional: public CDN / custom domain, e.g. https://cdn.example.com
# If omitted, public COS URL https://<bucket>.cos.<region>.myqcloud.com is used.
COS_BASE_URL=
